# Compiled object files, libraries, and executables
*.o
*.a
*.so
*.elf
*.map
*.hex
*.bin
*.out
*.exe

# Debug files
*.d

# Backup files
*~

# Autogenerated by IDE
*.launch
.settings/
.project
.cproject
*.prefs
*.user

# Build folders
Debug/
Release/
build/
*.jlink

# Simplicity Studio caches and build directory.
# NOTE (Jul 2026): autogen/ and config/ are now TRACKED. They were previously
# ignored, which made the project unrecoverable when Studio trashed them:
# the regenerated project silently lost the device_init_lfrco component
# (BLE stack pinned EM1, ~4.2 mA idle instead of ~1.6 mA) and the linkerfile
# lost its AppLoader offset (app linked at 0x0, clobbering the bootloader).
# Tracking them makes regeneration diffs visible and recovery possible.
.pdm/
.uceditor/
GNU*/

# Ignore assets that were part of the project
image/
*.pdf

# Misc
.DS_Store
Thumbs.db
